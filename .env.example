# ====================================
# Product Calculator Environment Variables
# ====================================

# MongoDB Configuration
# ===================
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-address>/<database>?retryWrites=true&w=majority

# JWT Configuration
# ================
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Email Configuration
# =================
# SMTP Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false  # true for port 465, false for other ports
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password-or-app-password

# Email Sender Information
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME="Product Calculator"

# Application Settings
# ==================
FLASK_APP=app.py
FLASK_ENV=development  # Set to 'production' in production
PORT=3000

# Security
# =======
# Set to 'True' in production
SECURE_COOKIES=False

# Logging
# ======
LOG_LEVEL=INFO

# Note: Copy this file to .env and fill in your actual values
# Never commit .env to version control
